<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="institute_crm.CrmDashboard" owl="1">
        <div class="o_action_manager o_crm_custom_dashboard pb-5 overflow-auto bg-100 h-100">
            <!-- Loading Indicator -->
            <t t-if="state.isLoading">
                <div class="d-flex w-100 h-100 align-items-center justify-content-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </t>

            <!-- Dashboard Content -->
            <t t-elif="state.data and !state.data.error">
                <div class="container-fluid pt-4">
                    <div class="row mb-4 align-items-center">
                        <div class="col-8">
                            <h1 class="display-6 fw-bold text-dark mb-1">
                                <t t-esc="state.data.welcome_message"/>
                            </h1>
                            <p class="text-muted mb-0"><t t-esc="state.data.today"/></p>
                        </div>
                        <div class="col-4 text-end">
                            <button class="btn btn-primary btn-lg rounded-pill fw-bold shadow border-0 px-4 py-2 text-white d-inline-flex align-items-center" t-on-click="() => this.openPipeline()" style="background: linear-gradient(135deg, #4f46e5, #7c3aed);">
                                <i class="fa fa-list-ul me-2 fs-5"></i> Goto Pipeline
                            </button>
                        </div>
                    </div>

                    <!-- ADMIN / MANAGER VIEW -->
                    <t t-if="state.data.is_manager">
                        
                        <!-- Smart Alerts -->
                        <div class="row g-4 mb-4">
                            <t t-if="state.data.alert_low_conversion_reps > 0 or state.data.alert_untouched_leads > 0 or state.data.alert_conversion_drop">
                                <div class="col-12">
                                    <div class="alert o_smart_alert shadow border-0 mb-0 d-flex flex-column gap-2" role="alert" style="background: rgba(254, 226, 226, 0.9); backdrop-filter: blur(10px); border-left: 5px solid #ef4444 !important; border-radius: 12px;">
                                        <h5 class="fw-bold mb-2 text-danger"><i class="fa fa-exclamation-triangle me-2" style="animation: pulse 2s infinite;"></i> Smart Alerts</h5>
                                        <div class="d-flex flex-wrap gap-3">
                                            <t t-if="state.data.alert_low_conversion_reps > 0">
                                                <div class="bg-white text-danger px-3 py-2 shadow-sm fw-bold d-flex align-items-center gap-2" style="border-radius: 8px;">
                                                    <i class="fa fa-users"></i> <t t-esc="state.data.alert_low_conversion_reps"/> salespeople have &lt;2% conversion
                                                </div>
                                            </t>
                                            <t t-if="state.data.alert_untouched_leads > 0">
                                                <div class="bg-white text-danger px-3 py-2 shadow-sm fw-bold d-flex align-items-center gap-2" style="border-radius: 8px;">
                                                    <i class="fa fa-clock-o"></i> <t t-esc="state.data.alert_untouched_leads"/> leads untouched for 3+ days
                                                </div>
                                            </t>
                                            <t t-if="state.data.alert_conversion_drop">
                                                <div class="bg-white text-danger px-3 py-2 shadow-sm fw-bold d-flex align-items-center gap-2" style="border-radius: 8px;">
                                                    <i class="fa fa-arrow-down"></i> Drop in conversions vs last week (<t t-esc="state.data.last_week_won"/> → <t t-esc="state.data.this_week_won"/>)
                                                </div>
                                            </t>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>

                        <!-- Revenue Intelligence & Metrics -->
                        <div class="row g-4 mb-4">
                            <!-- Revenue -->
                            <div class="col-md-8">
                                <div class="card shadow-sm border-0 h-100 text-white o_revenue_card" style="background: linear-gradient(135deg, #10b981 0%, #047857 100%); border-radius: 16px;">
                                    <div class="card-body p-4 position-relative overflow-hidden">
                                        <i class="fa fa-money fa-5x position-absolute opacity-10" style="right: -10px; bottom: -10px; transform: rotate(-15deg);"></i>
                                        <h5 class="fw-bold opacity-75 mb-4 text-uppercase tracking-wide"><i class="fa fa-line-chart me-2"></i> Revenue Intelligence</h5>
                                        <div class="row g-4">
                                            <div class="col-sm-6 col-md-4">
                                                <h3 class="fw-bold mb-0">₹<t t-esc="state.data.revenue.month.toLocaleString()"/></h3>
                                                <p class="small opacity-75 mb-0 fw-medium">Monthly Revenue</p>
                                            </div>
                                            <div class="col-sm-6 col-md-4">
                                                <h3 class="fw-bold mb-0">₹<t t-esc="state.data.revenue.today.toLocaleString()"/></h3>
                                                <p class="small opacity-75 mb-0 fw-medium">Today's Revenue</p>
                                            </div>
                                            <div class="col-sm-6 col-md-4">
                                                <h4 class="fw-bold mb-0">₹<t t-esc="state.data.revenue.total.toLocaleString()"/></h4>
                                                <p class="small opacity-75 mb-0 fw-medium">Total All Time</p>
                                            </div>
                                            <div class="col-sm-6 col-md-4">
                                                <h4 class="fw-bold mb-0">₹<t t-esc="Math.round(state.data.revenue.avg_deal).toLocaleString()"/></h4>
                                                <p class="small opacity-75 mb-0 fw-medium">Avg Deal Value</p>
                                            </div>
                                            <div class="col-sm-6 col-md-8">
                                                <h4 class="fw-bold mb-0 text-warning" style="text-shadow: 0 2px 4px rgba(0,0,0,0.2);">₹<t t-esc="state.data.revenue.forecast.toLocaleString()"/></h4>
                                                <p class="small opacity-75 mb-0 fw-medium">Forecasted Pipeline Revenue</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Other Metrics -->
                            <div class="col-md-4">
                                <div class="row g-3 h-100">
                                    <div class="col-12">
                                        <div class="card shadow-sm border-0 bg-primary text-white h-100 o_hover_lift" t-on-click="() => this.openConvertedLeads(true)" style="border-radius: 12px; cursor: pointer; background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);">
                                            <div class="card-body p-3 d-flex align-items-center justify-content-between">
                                                <div>
                                                    <h3 class="display-6 fw-bold mb-0"><t t-esc="state.data.total_admissions"/></h3>
                                                    <p class="mb-0 fw-medium small">Total Admissions</p>
                                                </div>
                                                <div class="bg-white bg-opacity-25 p-3 rounded-circle d-flex align-items-center justify-content-center">
                                                    <i class="fa fa-graduation-cap fa-2x"></i>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="card shadow-sm border-0 bg-warning text-dark h-100 o_hover_lift" style="border-radius: 12px;">
                                            <div class="card-body p-3 text-center d-flex flex-column justify-content-center">
                                                <h4 class="fw-bold mb-1"><t t-esc="state.data.team_week_count"/></h4>
                                                <small class="fw-bold opacity-75">Week Pending</small>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="card shadow-sm border-0 bg-info text-white h-100 o_hover_lift" style="border-radius: 12px; background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);">
                                            <div class="card-body p-3 text-center d-flex flex-column justify-content-center">
                                                <h4 class="fw-bold mb-1"><t t-esc="state.data.avg_lead_closure_days"/> <span class="fs-6">days</span></h4>
                                                <small class="fw-bold opacity-75">Avg Closure</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Performance & Heatmap -->
                        <div class="row g-4 mb-4">
                            <!-- Team Heatmap -->
                            <div class="col-md-12">
                                <div class="card shadow-sm border-0" style="border-radius: 16px;">
                                    <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                                        <h5 class="card-title fw-bold text-dark mb-0"><i class="fa fa-th me-2 text-primary"></i> Team Comparison Heatmap</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="d-flex flex-wrap gap-3">
                                            <t t-foreach="state.data.salesperson_perf" t-as="perf" t-key="perf.user">
                                                <t t-set="bg_color" t-value="perf.win_rate >= 20 ? 'bg-success' : (perf.win_rate >= 10 ? 'bg-info' : (perf.win_rate >= 5 ? 'bg-warning' : 'bg-danger'))"/>
                                                <t t-set="text_color" t-value="perf.win_rate >= 5 and perf.win_rate &lt; 10 ? 'text-dark' : 'text-white'"/>
                                                <div t-attf-class="p-4 rounded-4 shadow-sm flex-fill text-center {{bg_color}} {{text_color}} o_heatmap_card" style="min-width: 160px;">
                                                    <h6 class="fw-bold mb-2 text-uppercase tracking-wide"><t t-esc="perf.user"/></h6>
                                                    <h2 class="fw-bold mb-1"><t t-esc="perf.win_rate"/>%</h2>
                                                    <div class="badge bg-white bg-opacity-25 rounded-pill px-3 py-2 mt-2">
                                                        <t t-esc="perf.won"/> / <t t-esc="perf.total"/> leads
                                                    </div>
                                                </div>
                                            </t>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Trends & Sources -->
                        <div class="row g-4 mb-4">
                            <!-- Time-based Trends -->
                            <div class="col-md-7">
                                <div class="card shadow-sm border-0 h-100" style="border-radius: 16px;">
                                    <div class="card-header bg-white border-0 pt-4 pb-0">
                                        <h5 class="card-title fw-bold text-dark"><i class="fa fa-area-chart me-2 text-primary"></i> Last 7 Days Trend</h5>
                                    </div>
                                    <div class="card-body d-flex flex-column justify-content-end pb-2">
                                        <div class="d-flex justify-content-between align-items-end h-100 w-100 mt-2 px-3 pb-3 border-bottom" style="min-height: 220px;">
                                            <t t-set="max_val" t-value="Math.max(...state.data.time_trends.activities, ...state.data.time_trends.admissions, 1)"/>
                                            <t t-foreach="state.data.time_trends.labels" t-as="label" t-key="label">
                                                <div class="d-flex flex-column align-items-center w-100">
                                                    <div class="d-flex gap-2 align-items-end justify-content-center w-100" style="height: 180px;">
                                                        <!-- Activities Bar -->
                                                        <div class="rounded-top o_bar_chart" t-attf-style="background: linear-gradient(180deg, #3b82f6 0%, #2563eb 100%); width: 20px; height: {{ (state.data.time_trends.activities[label_index] / max_val) * 100 }}%; min-height: 4px;" t-att-title="'Activities: ' + state.data.time_trends.activities[label_index]"></div>
                                                        <!-- Admissions Bar -->
                                                        <div class="rounded-top o_bar_chart" t-attf-style="background: linear-gradient(180deg, #10b981 0%, #059669 100%); width: 20px; height: {{ (state.data.time_trends.admissions[label_index] / max_val) * 100 }}%; min-height: 4px;" t-att-title="'Admissions: ' + state.data.time_trends.admissions[label_index]"></div>
                                                    </div>
                                                    <small class="text-muted mt-3 fw-bold"><t t-esc="label"/></small>
                                                </div>
                                            </t>
                                        </div>
                                        <div class="d-flex justify-content-center gap-4 mt-3 mb-1">
                                            <div class="d-flex align-items-center gap-2"><span class="badge rounded-pill" style="background: #3b82f6;">&amp;nbsp;&amp;nbsp;</span> <small class="fw-bold text-muted">Activities</small></div>
                                            <div class="d-flex align-items-center gap-2"><span class="badge rounded-pill" style="background: #10b981;">&amp;nbsp;&amp;nbsp;</span> <small class="fw-bold text-muted">Admissions</small></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Lead Source -->
                            <div class="col-md-5">
                                <div class="card shadow-sm border-0 h-100" style="border-radius: 16px;">
                                    <div class="card-header bg-white border-0 pt-4 pb-0">
                                        <h5 class="card-title fw-bold text-dark"><i class="fa fa-pie-chart me-2 text-primary"></i> Top Source Performance</h5>
                                    </div>
                                    <div class="card-body pt-4">
                                        <div class="d-flex flex-column gap-4">
                                            <t t-foreach="state.data.source_performance" t-as="src" t-key="src.source">
                                                <div>
                                                    <div class="d-flex justify-content-between mb-2">
                                                        <span class="fw-bold text-dark fs-6"><t t-esc="src.source"/></span>
                                                        <span class="small fw-bold text-muted"><span class="text-success"><t t-esc="src.won"/> Won</span> / <span class="text-danger"><t t-esc="src.lost"/> Lost</span></span>
                                                    </div>
                                                    <div class="progress shadow-sm overflow-visible" style="height: 10px; border-radius: 10px; background-color: #f1f5f9;">
                                                        <t t-set="won_pct" t-value="src.total > 0 ? (src.won / src.total * 100) : 0"/>
                                                        <t t-set="lost_pct" t-value="src.total > 0 ? (src.lost / src.total * 100) : 0"/>
                                                        <div class="progress-bar rounded-pill z-1 position-relative" role="progressbar" t-attf-style="background: linear-gradient(90deg, #34d399 0%, #10b981 100%); width: {{ won_pct }}%; box-shadow: 0 0 10px rgba(16,185,129,0.5);"></div>
                                                        <div class="progress-bar rounded-pill position-relative" role="progressbar" t-attf-style="background: linear-gradient(90deg, #f87171 0%, #ef4444 100%); width: {{ lost_pct }}%; margin-left: -5px;"></div>
                                                    </div>
                                                </div>
                                            </t>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Funnel & Notes -->
                        <div class="row g-4 mb-4">
                            <!-- Funnel -->
                            <div class="col-md-5">
                                <div class="card shadow-sm border-0 h-100" style="border-radius: 16px;">
                                    <div class="card-header bg-white border-0 pt-4 pb-0">
                                        <h5 class="card-title fw-bold text-dark"><i class="fa fa-filter me-2 text-primary"></i> Pipeline Funnel</h5>
                                    </div>
                                    <div class="card-body d-flex flex-column align-items-center justify-content-center py-4">
                                        <t t-set="max_funnel" t-value="state.data.funnel.length > 0 ? state.data.funnel[0].count : 1"/>
                                        <t t-foreach="state.data.funnel" t-as="f" t-key="f.stage">
                                            <t t-set="width_pct" t-value="95 - (f_index * 12)"/>
                                            <t t-set="width_pct" t-value="width_pct &lt; 30 ? 30 : width_pct"/>
                                            <div class="d-flex align-items-center justify-content-center text-white fw-bold shadow-sm mb-2 position-relative o_funnel_stage"
                                                 t-attf-style="background: linear-gradient(90deg, #6366f1 0%, #4f46e5 100%); width: {{width_pct}}%; height: 48px; clip-path: polygon(5% 0%, 95% 0%, 100% 100%, 0% 100%); transition: transform 0.3s;">
                                                <span class="z-1" style="text-shadow: 0 1px 2px rgba(0,0,0,0.3);"><t t-esc="f.stage"/> (<t t-esc="f.count"/>)</span>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Notes -->
                            <div class="col-md-7">
                                <div class="card shadow-sm border-0 position-relative h-100 o_notes_card" style="background: linear-gradient(135deg, #fef9c3 0%, #fde047 100%); border-radius: 16px;">
                                    <div class="card-body p-4">
                                        <h5 class="fw-bold text-dark opacity-75 mb-3"><i class="fa fa-thumb-tack me-2" style="transform: rotate(-20deg);"></i> My Personal Notes</h5>
                                        <textarea 
                                            class="form-control border-0 bg-transparent text-dark w-100 p-0 fs-5 fw-medium" 
                                            rows="6" 
                                            style="resize: none; box-shadow: none; line-height: 1.6;"
                                            placeholder="Jot down quick thoughts, reminders, or goals here..."
                                            t-on-change="(ev) => this.onChangeStickyNote(ev)">
                                            <t t-esc="state.data.admin_sticky_note"/>
                                        </textarea>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Team Activities -->
                        <div class="row g-4 mb-4">
                            <!-- Today Team Tasks -->
                            <div class="col-md-6">
                                <div class="card shadow-sm border-0 h-100" style="border-radius: 16px;">
                                    <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between">
                                        <h5 class="card-title fw-bold text-danger"><i class="fa fa-calendar-check-o me-2"></i> Team Pending Today (<t t-esc="state.data.team_activities_today.length"/>)</h5>
                                    </div>
                                    <div class="card-body overflow-auto custom-scrollbar" style="max-height: 400px;">
                                        <t t-if="state.data.team_activities_today.length > 0">
                                            <div class="list-group list-group-flush gap-2">
                                                <t t-foreach="state.data.team_activities_today" t-as="activity" t-key="activity.id">
                                                    <button class="list-group-item list-group-item-action d-flex justify-content-between align-items-center p-3 rounded-3 shadow-sm border-0 bg-light"
                                                            t-on-click="() => this.openActivity('crm.lead', activity.res_id)" style="transition: transform 0.2s;">
                                                        <div>
                                                            <strong class="d-block text-dark"><t t-esc="activity.display_name"/></strong>
                                                            <small class="text-muted"><t t-esc="activity.summary or 'Task'"/></small>
                                                        </div>
                                                        <div class="text-end">
                                                            <span class="badge bg-danger text-white rounded-pill px-3 py-2 shadow-sm"><t t-esc="activity.user_name"/></span>
                                                        </div>
                                                    </button>
                                                </t>
                                            </div>
                                        </t>
                                        <t t-else="">
                                            <div class="d-flex flex-column align-items-center justify-content-center h-100 py-5 text-muted">
                                                <i class="fa fa-check-circle-o fa-4x mb-3 text-success opacity-50"></i>
                                                <p class="mb-0 fw-bold">No team activities due today.</p>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </div>

                            <!-- Week Team Tasks -->
                            <div class="col-md-6">
                                <div class="card shadow-sm border-0 h-100" style="border-radius: 16px;">
                                    <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between">
                                        <h5 class="card-title fw-bold text-warning"><i class="fa fa-calendar me-2"></i> Team Pending This Week (<t t-esc="state.data.team_activities_week.length"/>)</h5>
                                    </div>
                                    <div class="card-body overflow-auto custom-scrollbar" style="max-height: 400px;">
                                        <t t-if="state.data.team_activities_week.length > 0">
                                            <div class="list-group list-group-flush gap-2">
                                                <t t-foreach="state.data.team_activities_week" t-as="activity" t-key="activity.id">
                                                    <button class="list-group-item list-group-item-action d-flex justify-content-between align-items-center p-3 rounded-3 shadow-sm border-0 bg-light"
                                                            t-on-click="() => this.openActivity('crm.lead', activity.res_id)" style="transition: transform 0.2s;">
                                                        <div>
                                                            <strong class="d-block text-dark"><t t-esc="activity.display_name"/></strong>
                                                            <small class="text-muted"><t t-esc="activity.summary or 'Task'"/></small>
                                                        </div>
                                                        <div class="text-end">
                                                            <span class="badge bg-warning text-dark rounded-pill px-3 py-2 shadow-sm"><t t-esc="activity.user_name"/></span>
                                                            <div class="mt-2 small text-muted fw-bold"><t t-esc="activity.date_deadline"/></div>
                                                        </div>
                                                    </button>
                                                </t>
                                            </div>
                                        </t>
                                        <t t-else="">
                                            <div class="d-flex flex-column align-items-center justify-content-center h-100 py-5 text-muted">
                                                <i class="fa fa-calendar-check-o fa-4x mb-3 opacity-50"></i>
                                                <p class="mb-0 fw-bold">No team activities pending this week.</p>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>

                    <!-- REGULAR SALESPERSON VIEW -->
                    <t t-else="">
                        <div class="row g-4 mb-4">
                            <!-- Hero Metrics -->
                            <div class="col-md-4">
                                <div class="card shadow-sm border-0 bg-success text-white h-100 o_card_stat" t-on-click="() => this.openConvertedLeads(false)">
                                    <div class="card-body py-4 d-flex flex-column justify-content-center align-items-center text-center">
                                        <i class="fa fa-trophy fa-2x mb-3 opacity-75"></i>
                                        <h2 class="display-4 fw-bold mb-0"><t t-esc="state.data.converted_leads"/></h2>
                                        <p class="mb-0 fw-medium">Overall Leads Converted</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Quotes & AI Suggestion -->
                            <div class="col-md-8">
                                <div class="d-flex flex-column gap-4 h-100">
                                    <div class="card shadow-sm border-0 flex-fill bg-gradient-brand text-white overflow-hidden" style="background: linear-gradient(135deg, #714B67 0%, #017E84 100%);">
                                        <div class="card-body p-4 d-flex flex-column justify-content-center position-relative">
                                            <i class="fa fa-quote-left fa-3x opacity-25 position-absolute top-0 start-0 m-3"></i>
                                            <h4 class="fw-light text-center fst-italic px-4 z-1">"<t t-esc="state.data.quote"/>"</h4>
                                        </div>
                                    </div>
                                    <div class="card shadow-sm border-0 flex-fill border-start border-warning border-4">
                                        <div class="card-body py-3 overflow-auto">
                                            <div class="d-flex justify-content-between align-items-center mb-3">
                                                <h6 class="text-uppercase text-warning fw-bold mb-0"><i class="fa fa-lightbulb-o me-2"></i> AI Suggestions</h6>
                                                <t t-if="!state.aiSuggestions and !state.isAiLoading">
                                                    <button class="btn btn-sm btn-warning fw-bold text-dark rounded-pill shadow-sm" t-on-click="() => this.fetchAiSuggestions()">
                                                        <i class="fa fa-magic me-1"></i> Generate
                                                    </button>
                                                </t>
                                            </div>
                                            
                                            <t t-if="state.isAiLoading">
                                                <div class="d-flex justify-content-center py-4">
                                                    <div class="spinner-border text-warning" role="status">
                                                        <span class="visually-hidden">Loading...</span>
                                                    </div>
                                                </div>
                                            </t>
                                            <t t-elif="state.aiSuggestions">
                                                <div class="d-flex flex-column gap-3">
                                                    <t t-foreach="state.aiSuggestions" t-as="suggestion" t-key="suggestion.lead_id || suggestion_index">
                                                        <div class="border-bottom pb-3 mb-1 border-warning border-opacity-25 border-1">
                                                            <t t-if="suggestion.lead_id">
                                                                <div class="d-flex justify-content-between align-items-start mb-2">
                                                                    <h6 class="fw-bold mb-0 text-dark"><t t-esc="suggestion.suggested_action"/></h6>
                                                                </div>
                                                                <p class="fs-6 mb-2 text-muted fst-italic">"<t t-esc="suggestion.draft_message"/>"</p>
                                                                <div class="d-flex gap-2">
                                                                    <button class="btn btn-outline-warning btn-sm fw-bold rounded-pill" t-on-click="() => this.openLead(suggestion.lead_id)">
                                                                        <i class="fa fa-folder-open me-1"></i> Open <t t-esc="suggestion.lead_name"/>
                                                                    </button>
                                                                    <button class="btn btn-outline-secondary btn-sm fw-bold rounded-pill" t-on-click="() => this.copyDraft(suggestion.draft_message)">
                                                                        <i class="fa fa-copy me-1"></i> Copy Draft
                                                                    </button>
                                                                </div>
                                                            </t>
                                                            <t t-else="">
                                                                <h6 class="fw-bold mb-1 text-dark"><t t-esc="suggestion.suggested_action"/></h6>
                                                                <p class="fs-6 mb-0 text-muted"><t t-esc="suggestion.draft_message"/></p>
                                                            </t>
                                                        </div>
                                                    </t>
                                                </div>
                                            </t>
                                            <t t-else="">
                                                <div class="text-center py-4">
                                                    <p class="text-muted mb-0">Click generate to analyze your pipeline for personalized advice.</p>
                                                </div>
                                            </t>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- User Activities -->
                        <div class="row g-4">
                            <!-- Today User Tasks -->
                            <div class="col-md-6">
                                <div class="card shadow-sm border-0 h-100">
                                    <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between">
                                        <h5 class="card-title fw-bold text-danger">Pending Today (<t t-esc="state.data.activities_today.length"/>)</h5>
                                    </div>
                                    <div class="card-body overflow-auto" style="max-height: 450px;">
                                        <t t-if="state.data.activities_today.length > 0">
                                            <div class="list-group list-group-flush">
                                                <t t-foreach="state.data.activities_today" t-as="activity" t-key="activity.id">
                                                    <button class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3"
                                                            t-on-click="() => this.openActivity('crm.lead', activity.res_id)">
                                                        <div>
                                                            <strong class="d-block text-dark"><t t-esc="activity.display_name"/></strong>
                                                            <small class="text-muted"><t t-esc="activity.summary or 'Task'"/></small>
                                                        </div>
                                                        <i class="fa fa-chevron-right text-muted small"></i>
                                                    </button>
                                                </t>
                                            </div>
                                        </t>
                                        <t t-else="">
                                            <div class="text-center my-5 text-muted">
                                                <i class="fa fa-check-circle fa-4x mb-3 text-success opacity-50"></i>
                                                <h5>All caught up for today!</h5>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </div>

                            <!-- Week User Tasks -->
                            <div class="col-md-6">
                                <div class="card shadow-sm border-0 h-100">
                                    <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between">
                                        <h5 class="card-title fw-bold text-warning">Pending This Week (<t t-esc="state.data.activities_week.length"/>)</h5>
                                    </div>
                                    <div class="card-body overflow-auto" style="max-height: 450px;">
                                        <t t-if="state.data.activities_week.length > 0">
                                            <div class="list-group list-group-flush">
                                                <t t-foreach="state.data.activities_week" t-as="activity" t-key="activity.id">
                                                    <button class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-3"
                                                            t-on-click="() => this.openActivity('crm.lead', activity.res_id)">
                                                        <div>
                                                            <strong class="d-block text-dark"><t t-esc="activity.display_name"/></strong>
                                                            <small class="text-muted"><t t-esc="activity.summary or 'Task'"/></small>
                                                        </div>
                                                        <div class="text-end">
                                                            <div class="small fw-bold text-muted"><t t-esc="activity.date_deadline"/></div>
                                                        </div>
                                                    </button>
                                                </t>
                                            </div>
                                        </t>
                                        <t t-else="">
                                            <div class="text-center my-5 text-muted">
                                                <p>Nothing pending this week.</p>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </t>
                </div>
            </t>
            
            <!-- Error State -->
            <t t-else="">
                <div class="alert alert-danger m-4 shadow-sm" role="alert">
                    <h4 class="alert-heading">Error</h4>
                    <p>Failed to load dashboard data. Please try refreshing.</p>
                </div>
            </t>
        </div>
    </t>
</templates>
