<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_institute_admission_report_wizard_form" model="ir.ui.view">
        <field name="name">institute.admission.report.wizard.form</field>
        <field name="model">institute.admission.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Admission Report">
                <group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                    <group>
                        <field name="report_type"/>
                        <field name="branch_id" invisible="report_type != 'college'"/>
                    </group>
                </group>
                <footer>
                    <button name="action_generate_report" string="View Report" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_admission_report" model="ir.actions.act_window">
        <field name="name">Admission Report</field>
        <field name="res_model">institute.admission.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{}</field>
    </record>

</odoo>
