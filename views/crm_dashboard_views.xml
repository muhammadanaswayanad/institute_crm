<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_crm_dashboard" model="ir.actions.client">
        <field name="name">Dashboard</field>
        <field name="tag">institute_crm_dashboard</field>
    </record>

    <!-- Add Dashboard menu as first submenu -->
    <menuitem id="menu_crm_dashboard"
              name="Dashboard"
              parent="crm.crm_menu_root"
              action="action_crm_dashboard"
              sequence="1"/>
              
    <!-- Make Dashboard the main action for the CRM App root menu -->
    <record id="crm.crm_menu_root" model="ir.ui.menu">
        <field name="action" ref="institute_crm.action_crm_dashboard"/>
    </record>
</odoo>
