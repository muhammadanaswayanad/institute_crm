<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_inherit_dashboard" model="ir.ui.view">
        <field name="name">res.users.form.inherit.dashboard</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook/page[@name='access_rights']" position="inside">
                <group string="CRM Dashboard Settings">
                    <field name="hide_from_dashboard"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
