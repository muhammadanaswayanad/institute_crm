<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_lead_ai_suggestion_wizard_form" model="ir.ui.view">
        <field name="name">crm.lead.ai.suggestion.wizard.form</field>
        <field name="model">crm.lead.ai.suggestion.wizard</field>
        <field name="arch" type="xml">
            <form string="AI Suggestions">
                <sheet>
                    <field name="is_generated" invisible="1"/>
                    <field name="lead_id" invisible="1"/>
                    
                    <t invisible="is_generated">
                        <div class="text-center py-4">
                            <h4 class="text-dark mb-3">Analyze this lead with AI?</h4>
                            <p class="text-muted">This will analyze the student's selected course, recent log notes, and current stage to suggest your next best action and draft a WhatsApp message.</p>
                            <button name="action_generate_suggestion" type="object" string="Generate Suggestions" class="btn btn-warning btn-lg fw-bold rounded-pill text-dark my-3" icon="fa-magic"/>
                        </div>
                    </t>
                    
                    <div class="row" invisible="not is_generated">
                        <div class="col-12 mb-3">
                            <h4 class="text-warning"><i class="fa fa-lightbulb-o"></i> Suggested Next Action</h4>
                            <field name="suggested_action" nolabel="1" class="fs-5 fw-bold"/>
                        </div>
                        <div class="col-12 mt-3">
                            <h4 class="text-secondary"><i class="fa fa-comment-o"></i> Draft Message</h4>
                            <field name="draft_message" nolabel="1" widget="CopyClipboardText" class="fst-italic text-muted fs-6"/>
                        </div>
                    </div>
                </sheet>
                <footer>
                    <button name="action_generate_suggestion" invisible="not is_generated" type="object" string="Regenerate" class="btn-outline-warning text-dark me-2" icon="fa-refresh"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
