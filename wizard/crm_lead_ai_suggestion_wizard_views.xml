<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_lead_ai_suggestion_wizard_form" model="ir.ui.view">
        <field name="name">crm.lead.ai.suggestion.wizard.form</field>
        <field name="model">crm.lead.ai.suggestion.wizard</field>
        <field name="arch" type="xml">
            <form string="AI Suggestions">
                <sheet>
                    <field name="lead_id" invisible="1"/>
                    
                    <div class="row">
                        <div class="col-12 mb-4">
                            <h5 class="text-warning fw-bold mb-2"><i class="fa fa-lightbulb-o"></i> Suggested Next Action</h5>
                            <field name="suggested_action" nolabel="1" readonly="1" class="fs-5 text-dark border-0 bg-transparent w-100" style="resize: none;" widget="text"/>
                        </div>
                        <div class="col-12 mt-2">
                            <h5 class="text-secondary fw-bold mb-2"><i class="fa fa-comment-o"></i> Draft Message (Ready to Copy)</h5>
                            <div class="bg-light p-3 rounded shadow-sm border border-secondary border-opacity-25">
                                <field name="draft_message" nolabel="1" widget="CopyClipboardText" readonly="1" class="fst-italic text-muted fs-6"/>
                            </div>
                        </div>
                    </div>
                </sheet>
                <footer>
                    <button name="action_generate_suggestion" type="object" string="Regenerate" class="btn-outline-warning text-dark me-2" icon="fa-refresh"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
